# Arbitrum 主网 RPC 节点
ARBITRUM_RPC_URL_1=https://arbitrum-mainnet.infura.io/v3/YOUR_INFURA_KEY
ARBITRUM_RPC_URL_2=https://arbitrum-mainnet.core.chainstack.com/YOUR_CHAINSTACK_PATH

# 热钱包私钥（以 0x 开头）
OPERATOR_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# 部署的套利合约地址
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS

# ==================== 🆕 每组套利对专属最小利润门槛 (Env 优先，Config 兜底) ====================
# 你可以根据每组套利对池子的大小，在 .env 里通过 'PAIR_组号_MIN_PROFIT' 随时微调某组的门槛。
# 比如大池子设高（防滑点磨损），小池子设低（高频抓肉）。
# 如果 .env 里面没写该变量，则系统全自动 fallback 退化到下面的本地硬编码默认值！
# 只有通过门槛的复筛，才能有交易资格，而交易资格的参数设定，是以通过门槛的最小档位来定。
# 以目前的weth和wbtc的价格来说，
1美元 = 0.0003 weth
1美元 = 0.000016 wbtc

PAIR_0_MIN_PROFIT=0.0003
PAIR_1_MIN_PROFIT=0.0012
PAIR_2_MIN_PROFIT=0.0003
PAIR_3_MIN_PROFIT=0.0003
PAIR_4_MIN_PROFIT=0.0003
PAIR_5_MIN_PROFIT=0.003
PAIR_6_MIN_PROFIT=0.000048
PAIR_7_MIN_PROFIT=0.000016
PAIR_8_MIN_PROFIT=0.00008


# 套利合约初筛频率（秒）
CHECK_INTERVAL=1.2